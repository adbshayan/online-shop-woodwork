---
// Contact section — studio details, socials, and the demo message form.
const whatsappHref =
  'https://wa.me/982188880000?text=%D8%B3%D9%84%D8%A7%D9%85%D8%8C%20%D8%A7%D8%B2%20%D8%B3%D8%A7%DB%8C%D8%AA%20%D8%B1%D9%88%D8%B2%D8%B1%DB%8C%20%D9%BE%DB%8C%D8%A7%D9%85%20%D9%85%DB%8C%E2%80%8C%D8%AF%D9%87%D9%85.';
---

<section id="contact" class="contact">
  <div class="container cgrid">
    <div class="cinfo reveal">
      <span class="eyebrow" data-en="Contact" data-fa="تماس">تماس</span>
      <h2 style="margin-top:16px" data-en="Come see the work in person." data-fa="کارها را از نزدیک ببینید.">کارها را از نزدیک ببینید.</h2>
      <p class="body" data-en="The studio is open by appointment — to feel the weight of a top, the softness of an edge, the way a drawer closes. Retail and trade visitors both welcome." data-fa="استودیو با هماهنگی قبلی پذیرای شماست — تا وزن یک رویه، نرمی یک لبه، و صدای بسته‌شدن یک کشو را از نزدیک حس کنید. از خریداران و همکاران تجاری، هر دو، استقبال می‌کنیم.">استودیو با هماهنگی قبلی پذیرای شماست — تا وزن یک رویه، نرمی یک لبه، و صدای بسته‌شدن یک کشو را از نزدیک حس کنید. از خریداران و همکاران تجاری، هر دو، استقبال می‌کنیم.</p>
      <div class="details">
        <div class="row"><span class="k" data-en="Studio & showroom" data-fa="استودیو و نمایشگاه">استودیو و نمایشگاه</span><span class="v" data-en="No. 14, Sohrevardi St., Tehran" data-fa="تهران، خیابان سهروردی، پلاک ۱۴">تهران، خیابان سهروردی، پلاک ۱۴</span></div>
        <div class="row"><span class="k" data-en="Phone & WhatsApp" data-fa="تلفن و واتساپ">تلفن و واتساپ</span><span class="v" data-en="+98 21 8888 0000" data-fa="۰۲۱ ۸۸۸۸ ۰۰۰۰">۰۲۱ ۸۸۸۸ ۰۰۰۰</span></div>
        <div class="row"><span class="k" data-en="Hours" data-fa="ساعات کاری">ساعات کاری</span><span class="v" data-en="Saturday – Thursday · 10:00 – 19:00" data-fa="شنبه تا پنج‌شنبه · ۱۰:۰۰ تا ۱۹:۰۰">شنبه تا پنج‌شنبه · ۱۰:۰۰ تا ۱۹:۰۰</span></div>
        <div class="row"><span class="k" data-en="Elsewhere" data-fa="شبکه‌ها">شبکه‌ها</span><span class="v">Instagram @rosary.atelier · hello@rosary.ir</span></div>
      </div>
      <div class="socials">
        <a class="social" href={whatsappHref} target="_blank" rel="noopener" aria-label="WhatsApp" title="WhatsApp">
          <svg viewBox="0 0 24 24" role="img" aria-hidden="true"><path d="M17.47 14.38c-.29-.15-1.7-.84-1.96-.93-.26-.1-.45-.15-.65.14-.19.29-.74.93-.9 1.12-.17.19-.33.22-.62.07-.29-.15-1.22-.45-2.32-1.44-.86-.76-1.44-1.7-1.6-1.99-.17-.29-.02-.45.13-.59.13-.13.29-.34.44-.51.14-.17.19-.29.29-.48.1-.19.05-.36-.02-.51-.07-.15-.65-1.57-.9-2.15-.24-.56-.48-.48-.65-.49-.17-.01-.36-.01-.55-.01-.19 0-.51.07-.77.36-.26.29-1.01.99-1.01 2.41 0 1.42 1.04 2.79 1.18 2.98.15.19 2.05 3.13 4.96 4.39.69.3 1.23.48 1.65.61.69.22 1.33.19 1.83.12.56-.08 1.7-.7 1.94-1.37.24-.67.24-1.25.17-1.37-.07-.12-.26-.19-.55-.34zM12.05 21.5h-.01a9.5 9.5 0 0 1-4.83-1.32l-.35-.21-3.59.94.96-3.5-.23-.36a9.45 9.45 0 0 1-1.45-5.04c0-5.23 4.26-9.48 9.5-9.48 2.54 0 4.92.99 6.71 2.78a9.42 9.42 0 0 1 2.78 6.71c0 5.23-4.26 9.48-9.5 9.48zm8.08-17.56A11.34 11.34 0 0 0 12.05 0C5.79 0 .7 5.09.7 11.35c0 2 .52 3.95 1.52 5.67L.6 24l7.14-1.87a11.32 11.32 0 0 0 5.41 1.38h.01c6.26 0 11.35-5.09 11.35-11.35 0-3.03-1.18-5.88-3.32-8.02z"></path></svg>
        </a>
        <a class="social" href="https://t.me/rosary_atelier" target="_blank" rel="noopener" aria-label="Telegram" title="Telegram">
          <svg viewBox="0 0 24 24" role="img" aria-hidden="true"><path d="M23.91 3.79 20.3 20.84c-.25 1.21-.98 1.5-2 .94l-5.5-4.07-2.66 2.57c-.3.3-.55.56-1.1.56l.38-5.56 10.11-9.14c.44-.39-.1-.61-.68-.22L6.8 13.7l-5.45-1.7c-1.18-.37-1.2-1.18.25-1.75l21.3-8.22c.98-.36 1.84.22 1.51 1.76z"></path></svg>
        </a>
        <a class="social" href="https://instagram.com/rosary.atelier" target="_blank" rel="noopener" aria-label="Instagram" title="Instagram">
          <svg viewBox="0 0 24 24" role="img" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.72 3.72 0 0 1-1.38-.9c-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0-2.16C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.31-1.46.72-2.12 1.38C1.36 2.67.95 3.34.63 4.14.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.8.72 1.47 1.38 2.13.66.66 1.33 1.07 2.12 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56.8-.31 1.47-.72 2.13-1.38.66-.66 1.07-1.33 1.38-2.13.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.88 5.88 0 0 0-1.38-2.13A5.88 5.88 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zm0 10.16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-10.4a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z"></path></svg>
        </a>
      </div>
    </div>

    <form class="form reveal d1" id="cform" novalidate>
      <h3 data-en="Send a message" data-fa="ارسال پیام">ارسال پیام</h3>
      <p class="sub" data-en="We reply within one working day." data-fa="حداکثر ظرف یک روز کاری پاسخ می‌دهیم.">حداکثر ظرف یک روز کاری پاسخ می‌دهیم.</p>
      <div class="field">
        <span class="flabel" data-en="I am a" data-fa="من یک…">من یک…</span>
        <div class="seg">
          <input type="radio" id="a1" name="kind" checked /><label for="a1" data-en="Personal buyer" data-fa="مشتری شخصی">مشتری شخصی</label>
          <input type="radio" id="a2" name="kind" /><label for="a2" data-en="Retailer / trade" data-fa="فروشنده / همکار تجاری">فروشنده / همکار تجاری</label>
        </div>
      </div>
      <div class="field"><span class="flabel" data-en="Name" data-fa="نام">نام</span><input type="text" name="name" autocomplete="name" /></div>
      <div class="field"><span class="flabel" data-en="Phone or email" data-fa="تلفن یا ایمیل">تلفن یا ایمیل</span><input type="text" name="contact" autocomplete="tel" /></div>
      <div class="field"><span class="flabel" data-en="Message" data-fa="پیام">پیام</span><textarea name="msg" rows="3"></textarea></div>
      <button type="submit" class="btn solid" data-en="Send" data-fa="ارسال">ارسال</button>
      <p class="done" data-en="Thank you — we'll be in touch shortly." data-fa="سپاسگزاریم — به‌زودی با شما تماس خواهیم گرفت.">سپاسگزاریم — به‌زودی با شما تماس خواهیم گرفت.</p>
    </form>
  </div>
</section>
